{
  "info": {
    "name": "Registro Estudiantes API",
    "description": "All endpoints for the Sistema de Registro de Estudiantes REST API.\n\nBefore running:\n1. Import the environment file (registro_api.postman_environment.json)\n2. Set the `api_key` variable to the key shown in Ajustes → API REST\n3. Make sure the app is running (mvn javafx:run)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [],
  "auth": {
    "type": "apikey",
    "apikey": [
      { "key": "key",   "value": "X-API-Key" },
      { "key": "value", "value": "{{api_key}}" },
      { "key": "in",    "value": "header" }
    ]
  },
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET /api/health",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{base_url}}/api/health", "host": ["{{base_url}}"], "path": ["api","health"] }
          }
        }
      ]
    },
