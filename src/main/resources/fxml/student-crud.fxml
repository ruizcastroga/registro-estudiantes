<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.control.cell.PropertyValueFactory?>
<?import javafx.scene.layout.*?>

<!--
    Vista de gestión de estudiantes (CRUD).
    Permite agregar, editar, eliminar y buscar estudiantes.
-->
<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.tuempresa.registro.controllers.StudentCRUDController"
            styleClass="crud-container"
            prefWidth="1000" prefHeight="700">

    <!-- Barra superior -->
    <top>
        <VBox styleClass="header-box">
            <HBox alignment="CENTER_LEFT" spacing="20">
                <padding>
                    <Insets top="15" right="20" bottom="15" left="20"/>
                </padding>

                <!-- Botón volver -->
                <Button fx:id="backButton" text="Volver al Scanner"
                        onAction="#onBackToScanner" styleClass="secondary-button"/>

                <Region HBox.hgrow="ALWAYS"/>

                <!-- Título -->
                <Label text="Gestión de Estudiantes" styleClass="page-title"/>

                <Region HBox.hgrow="ALWAYS"/>

                <!-- Búsqueda -->
                <HBox spacing="10" alignment="CENTER_RIGHT">
                    <TextField fx:id="searchField"
                               promptText="Buscar por nombre o código..."
                               prefWidth="250"
                               onAction="#onSearch"
                               styleClass="search-field"/>
                    <Button fx:id="searchButton" text="Buscar"
                            onAction="#onSearch" styleClass="primary-button"/>
                    <Button fx:id="clearSearchButton" text="Limpiar"
                            onAction="#onClearSearch" styleClass="small-button"/>
                </HBox>
            </HBox>
        </VBox>
    </top>

    <!-- Contenido principal dividido -->
    <center>
        <SplitPane dividerPositions="0.6" orientation="HORIZONTAL">
            <!-- Panel izquierdo: Tabla de estudiantes -->
            <VBox spacing="10">
                <padding>
                    <Insets top="15" right="10" bottom="15" left="15"/>
                </padding>

                <!-- Barra de acciones -->
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Button fx:id="newButton" text="Nuevo Estudiante"
                            onAction="#onNewStudent" styleClass="primary-button"/>
                    <Button fx:id="editButton" text="Editar"
                            onAction="#onEditStudent" styleClass="secondary-button"
                            disable="true"/>
                    <Button fx:id="deleteButton" text="Eliminar"
                            onAction="#onDeleteStudent" styleClass="danger-button"
                            disable="true"/>

                    <Separator orientation="VERTICAL"/>

                    <!-- Botones de importación CSV -->
                    <Button fx:id="importCsvButton" text="Importar CSV"
                            onAction="#onImportCsv" styleClass="secondary-button"/>
                    <Button fx:id="templateButton" text="Plantilla"
                            onAction="#onGenerateTemplate" styleClass="small-button"/>

                    <Region HBox.hgrow="ALWAYS"/>

                    <Label fx:id="countLabel" text="0 estudiantes" styleClass="count-label"/>
                </HBox>

                <!-- Tabla de estudiantes -->
                <TableView fx:id="studentsTable" VBox.vgrow="ALWAYS"
                           styleClass="students-table">
                    <columns>
                        <TableColumn fx:id="colBarcode" text="Código" prefWidth="100">
                            <cellValueFactory>
                                <PropertyValueFactory property="barcode"/>
                            </cellValueFactory>
                        </TableColumn>

                        <TableColumn fx:id="colFirstName" text="Nombre" prefWidth="150">
                            <cellValueFactory>
                                <PropertyValueFactory property="firstName"/>
                            </cellValueFactory>
                        </TableColumn>

                        <TableColumn fx:id="colLastName" text="Apellido" prefWidth="150">
                            <cellValueFactory>
                                <PropertyValueFactory property="lastName"/>
                            </cellValueFactory>
                        </TableColumn>

                        <TableColumn fx:id="colGrade" text="Grado" prefWidth="100">
                            <cellValueFactory>
                                <PropertyValueFactory property="grade"/>
                            </cellValueFactory>
                        </TableColumn>

                        <TableColumn fx:id="colRequiresGuardian" text="Req. Acomp." prefWidth="90">
                            <cellValueFactory>
                                <PropertyValueFactory property="requiresGuardian"/>
                            </cellValueFactory>
                        </TableColumn>

                        <TableColumn fx:id="colStatus" text="Estado" prefWidth="80">
                            <cellValueFactory>
                                <PropertyValueFactory property="status"/>
                            </cellValueFactory>
                        </TableColumn>
                    </columns>
                </TableView>
            </VBox>

            <!-- Panel derecho: Formulario de edición -->
            <VBox spacing="15" styleClass="form-panel">
                <padding>
                    <Insets top="15" right="15" bottom="15" left="10"/>
                </padding>

                <Label fx:id="formTitle" text="Nuevo Estudiante" styleClass="form-title"/>

                <Separator/>

                <!-- Formulario -->
                <GridPane hgap="10" vgap="15" styleClass="student-form">
                    <!-- Código de barras -->
                    <Label text="Código de Barras: *" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                    <TextField fx:id="barcodeField" GridPane.columnIndex="1" GridPane.rowIndex="0"
                               promptText="Escanee o ingrese el código"/>

                    <!-- Nombre -->
                    <Label text="Nombre: *" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                    <TextField fx:id="firstNameField" GridPane.columnIndex="1" GridPane.rowIndex="1"
                               promptText="Nombre(s) del estudiante"/>

                    <!-- Apellido -->
                    <Label text="Apellido: *" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                    <TextField fx:id="lastNameField" GridPane.columnIndex="1" GridPane.rowIndex="2"
                               promptText="Apellido(s) del estudiante"/>

                    <!-- Grado -->
                    <Label text="Grado/Curso:" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                    <TextField fx:id="gradeField" GridPane.columnIndex="1" GridPane.rowIndex="3"
                               promptText="Ej: 5to Primaria"/>

                    <!-- Es menor de edad -->
                    <Label text="Menor de edad:" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
                    <CheckBox fx:id="isMinorCheck" GridPane.columnIndex="1" GridPane.rowIndex="4"
                              selected="true"/>

                    <!-- Requiere acompañante -->
                    <Label text="Requiere acompañante:" GridPane.columnIndex="0" GridPane.rowIndex="5"/>
                    <CheckBox fx:id="requiresGuardianCheck" GridPane.columnIndex="1" GridPane.rowIndex="5"
                              selected="true"/>

                    <!-- Estado -->
                    <Label text="Estado:" GridPane.columnIndex="0" GridPane.rowIndex="6"/>
                    <ComboBox fx:id="statusCombo" GridPane.columnIndex="1" GridPane.rowIndex="6"
                              prefWidth="200"/>

                    <columnConstraints>
                        <ColumnConstraints minWidth="130" halignment="RIGHT"/>
                        <ColumnConstraints hgrow="ALWAYS" minWidth="200"/>
                    </columnConstraints>
                </GridPane>

                <Separator/>

                <!-- Sección de guardianes legales -->
                <VBox spacing="10">
                    <Label text="Guardianes Legales *" styleClass="section-title"/>
                    <Label text="(Obligatorio si requiere acompañante)" styleClass="hint-label"/>

                    <ListView fx:id="guardiansListView" prefHeight="120"
                              styleClass="guardians-list"/>

                    <HBox spacing="10">
                        <Button fx:id="addGuardianButton" text="Agregar Guardián"
                                onAction="#onAddGuardian" styleClass="small-button"/>
                        <Button fx:id="removeGuardianButton" text="Eliminar"
                                onAction="#onRemoveGuardian" styleClass="small-button"
                                disable="true"/>
                    </HBox>
                </VBox>

                <Region VBox.vgrow="ALWAYS"/>

                <!-- Botones de acción del formulario -->
                <HBox spacing="15" alignment="CENTER_RIGHT">
                    <Button fx:id="cancelButton" text="Cancelar"
                            onAction="#onCancel" styleClass="secondary-button"/>
                    <Button fx:id="saveButton" text="Guardar"
                            onAction="#onSave" styleClass="primary-button"/>
                </HBox>

                <!-- Mensaje de validación -->
                <Label fx:id="validationMessage" text="" styleClass="validation-message"/>
            </VBox>
        </SplitPane>
    </center>

    <!-- Barra inferior -->
    <bottom>
        <HBox styleClass="footer-box" alignment="CENTER_LEFT" spacing="20">
            <padding>
                <Insets top="10" right="20" bottom="10" left="20"/>
            </padding>

            <Label fx:id="statusMessage" text="Listo" styleClass="status-message"/>

            <Region HBox.hgrow="ALWAYS"/>

            <Label text="* Campos obligatorios" styleClass="required-note"/>
        </HBox>
    </bottom>
</BorderPane>
