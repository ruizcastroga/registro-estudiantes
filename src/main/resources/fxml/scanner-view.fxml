<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<!--
    Vista principal del scanner de códigos de barras.
    Esta pantalla es la que usa el guardia para escanear los carnés.
-->
<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.tuempresa.registro.controllers.ScannerController"
            styleClass="main-container"
            prefWidth="900" prefHeight="650">

    <!-- Barra superior con información general -->
    <top>
        <VBox styleClass="header-box">
            <HBox alignment="CENTER_LEFT" spacing="20">
                <padding>
                    <Insets top="15" right="20" bottom="15" left="20"/>
                </padding>

                <!-- Título de la aplicación -->
                <VBox HBox.hgrow="ALWAYS">
                    <Label fx:id="schoolNameLabel" text="Sistema de Registro de Estudiantes"
                           styleClass="app-title"/>
                    <Label fx:id="dateTimeLabel" text="Fecha y hora"
                           styleClass="datetime-label"/>
                </VBox>

                <!-- Estadísticas del día -->
                <VBox alignment="CENTER_RIGHT">
                    <Label text="Escaneos hoy:" styleClass="stats-label"/>
                    <Label fx:id="todayScansLabel" text="0" styleClass="stats-value"/>
                </VBox>

                <!-- Botón de gestión -->
                <Button fx:id="manageButton" text="Gestionar Estudiantes"
                        onAction="#onManageStudents" styleClass="secondary-button"/>
            </HBox>
        </VBox>
    </top>

    <!-- Área central principal -->
    <center>
        <VBox alignment="CENTER" spacing="30">
            <padding>
                <Insets top="30" right="40" bottom="30" left="40"/>
            </padding>

            <!-- Campo de entrada del scanner (oculto visualmente pero funcional) -->
            <TextField fx:id="barcodeInput"
                       promptText="Escanee el carné del estudiante..."
                       onAction="#onBarcodeScanned"
                       styleClass="barcode-input"
                       maxWidth="500"
                       alignment="CENTER"/>

            <!-- Instrucciones -->
            <Label fx:id="instructionLabel"
                   text="Escanee el carné del estudiante o escriba el código"
                   styleClass="instruction-label"/>

            <!-- Panel de resultado del escaneo -->
            <VBox fx:id="resultPanel" alignment="CENTER" spacing="15"
                  styleClass="result-panel" visible="false" managed="false">
                <padding>
                    <Insets top="30" right="40" bottom="30" left="40"/>
                </padding>

                <!-- Nombre del estudiante -->
                <Label fx:id="studentNameLabel" text=""
                       styleClass="student-name"/>

                <!-- Grado -->
                <Label fx:id="studentGradeLabel" text=""
                       styleClass="student-grade"/>

                <!-- Estado de salida (PUEDE SALIR / REQUIERE ACOMPAÑANTE) -->
                <Label fx:id="statusLabel" text=""
                       styleClass="status-label"/>

                <!-- Lista de acudientes (si requiere) -->
                <VBox fx:id="guardiansPanel" alignment="CENTER" spacing="5"
                      visible="false" managed="false">
                    <Label text="Acudientes autorizados:" styleClass="guardians-title"/>
                    <VBox fx:id="guardiansList" spacing="3" alignment="CENTER"/>
                </VBox>
            </VBox>

            <!-- Panel cuando no se encuentra el estudiante -->
            <VBox fx:id="notFoundPanel" alignment="CENTER" spacing="15"
                  styleClass="not-found-panel" visible="false" managed="false">
                <padding>
                    <Insets top="20" right="30" bottom="20" left="30"/>
                </padding>

                <Label fx:id="notFoundLabel" text="Estudiante no encontrado"
                       styleClass="not-found-message"/>

                <Label fx:id="scannedCodeLabel" text=""
                       styleClass="scanned-code"/>

                <Button fx:id="quickRegisterButton" text="Registrar Nuevo Estudiante"
                        onAction="#onQuickRegister" styleClass="primary-button"/>
            </VBox>
        </VBox>
    </center>

    <!-- Panel lateral derecho con historial -->
    <right>
        <VBox styleClass="history-panel" prefWidth="280">
            <padding>
                <Insets top="20" right="15" bottom="20" left="15"/>
            </padding>

            <Label text="Historial Reciente" styleClass="history-title"/>

            <Separator/>

            <ListView fx:id="historyListView" VBox.vgrow="ALWAYS"
                      styleClass="history-list"/>

            <HBox alignment="CENTER" spacing="10">
                <padding>
                    <Insets top="10"/>
                </padding>
                <Button fx:id="clearHistoryButton" text="Limpiar"
                        onAction="#onClearHistory" styleClass="small-button"/>
            </HBox>
        </VBox>
    </right>

    <!-- Barra inferior con estado -->
    <bottom>
        <HBox styleClass="footer-box" alignment="CENTER_LEFT" spacing="20">
            <padding>
                <Insets top="10" right="20" bottom="10" left="20"/>
            </padding>

            <!-- Indicador de estado -->
            <HBox alignment="CENTER_LEFT" spacing="8">
                <Label fx:id="statusIndicator" text="" styleClass="status-indicator"/>
                <Label fx:id="connectionStatusLabel" text="Conectado" styleClass="connection-status"/>
            </HBox>

            <Region HBox.hgrow="ALWAYS"/>

            <!-- Información de licencia -->
            <Label fx:id="licenseInfoLabel" text="Modo Demo" styleClass="license-info"/>

            <Separator orientation="VERTICAL"/>

            <!-- Versión -->
            <Label text="v1.0.0" styleClass="version-label"/>
        </HBox>
    </bottom>
</BorderPane>
