<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<!--
    Vista principal del scanner de códigos de barras.
    Esta pantalla es la que usa el guardia para escanear los carnés.
-->
<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.tuempresa.registro.controllers.ScannerController"
            styleClass="main-container">

    <!-- Barra superior con sesión + información general -->
    <top>
        <VBox>
            <!-- Barra de sesión -->
            <HBox fx:id="sessionBar" alignment="CENTER_LEFT" spacing="15" styleClass="session-bar" visible="false" managed="false">
                <padding><Insets top="8" right="20" bottom="8" left="20"/></padding>
                <Label fx:id="sessionUserLabel" text="" styleClass="session-user-label"/>
                <Label fx:id="sessionRoleLabel" text="" styleClass="session-role-label"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="sessionTimerLabel" text="00:00" styleClass="session-timer-label"/>
                <Button fx:id="sessionLoginBtn" text="Iniciar Sesión" onAction="#onLogin" styleClass="session-button"/>
                <Button fx:id="sessionLogoutBtn" text="Cerrar Sesión" onAction="#onLogout" styleClass="session-button" visible="false" managed="false"/>
            </HBox>

            <!-- Header original -->
            <VBox styleClass="header-box">
                <HBox alignment="CENTER_LEFT" spacing="20">
                    <padding>
                        <Insets top="15" right="20" bottom="15" left="20"/>
                    </padding>

                    <!-- Título de la aplicación -->
                    <VBox HBox.hgrow="ALWAYS">
                        <Label fx:id="schoolNameLabel" text="Sistema de Registro de Estudiantes"
                               styleClass="app-title"/>
                        <Label fx:id="dateTimeLabel" text="Fecha y hora"
                               styleClass="datetime-label"/>
                    </VBox>

                    <!-- Estadísticas del día -->
                    <VBox alignment="CENTER_RIGHT">
                        <Label text="Escaneos hoy:" styleClass="stats-label"/>
                        <Label fx:id="todayScansLabel" text="0" styleClass="stats-value"/>
                    </VBox>

                    <!-- Botones de navegación -->
                    <Button fx:id="manageButton" text="Estudiantes"
                            onAction="#onManageStudents" styleClass="secondary-button"/>
                    <Button text="Visitantes"
                            onAction="#onManageVisitors" styleClass="secondary-button"/>
                    <Button text="Personal"
                            onAction="#onManageStaff" styleClass="secondary-button"/>
                    <Button text="Creador de Carné"
                            onAction="#onManageCarne" styleClass="secondary-button"/>
                    <Button text="Ajustes"
                            onAction="#onManageSettings" styleClass="secondary-button"/>
                </HBox>
            </VBox>
        </VBox>
    </top>

    <!-- Área central principal -->
    <center>
        <VBox alignment="CENTER" spacing="30">
            <padding>
                <Insets top="30" right="40" bottom="30" left="40"/>
            </padding>

            <!-- Campo de entrada del scanner (oculto visualmente pero funcional) -->
            <TextField fx:id="barcodeInput"
                       promptText="Escanee el carné (estudiante, personal o visitante)..."
                       onAction="#onBarcodeScanned"
                       styleClass="barcode-input"
                       maxWidth="500"
                       alignment="CENTER"/>

            <!-- Instrucciones -->
            <Label fx:id="instructionLabel"
                   text="Escanee cualquier carné o escriba el código"
                   styleClass="instruction-label"/>

            <!-- Panel de resultado del escaneo (estudiante) -->
            <VBox fx:id="resultPanel" alignment="CENTER" spacing="15"
                  styleClass="result-panel" visible="false" managed="false">
                <padding>
                    <Insets top="30" right="40" bottom="30" left="40"/>
                </padding>

                <!-- Nombre del estudiante -->
                <Label fx:id="studentNameLabel" text=""
                       styleClass="student-name"/>

                <!-- Grado -->
                <Label fx:id="studentGradeLabel" text=""
                       styleClass="student-grade"/>

                <!-- Estado de salida (PUEDE SALIR / REQUIERE ACOMPAÑANTE) -->
                <Label fx:id="statusLabel" text=""
                       styleClass="status-label"/>

                <!-- Estado de actividad (INACTIVO / SUSPENDIDO) -->
                <Label fx:id="activityStatusLabel" text=""
                       styleClass="activity-status-label"
                       visible="false" managed="false"/>

                <!-- Lista de tutores legales (si requiere) -->
                <VBox fx:id="guardiansPanel" alignment="CENTER" spacing="5"
                      visible="false" managed="false">
                    <Label text="Tutores Legales:" styleClass="guardians-title"/>
                    <VBox fx:id="guardiansList" spacing="3" alignment="CENTER"/>
                </VBox>
            </VBox>

            <!-- Panel de resultado del escaneo (personal) -->
            <VBox fx:id="staffResultPanel" alignment="CENTER" spacing="15"
                  styleClass="result-panel" visible="false" managed="false">
                <padding>
                    <Insets top="30" right="40" bottom="30" left="40"/>
                </padding>

                <Label fx:id="staffNameLabel" text=""
                       styleClass="student-name"/>

                <Label fx:id="staffDepartmentLabel" text=""
                       styleClass="student-grade"/>

                <Label fx:id="staffStatusLabel" text=""
                       styleClass="status-label"/>
            </VBox>

            <!-- Panel de resultado del escaneo (visitante) -->
            <VBox fx:id="visitorResultPanel" alignment="CENTER" spacing="15"
                  styleClass="result-panel" visible="false" managed="false">
                <padding>
                    <Insets top="30" right="40" bottom="30" left="40"/>
                </padding>

                <Label fx:id="visitorNameLabel" text=""
                       styleClass="student-name"/>

                <Label fx:id="visitorBadgeLabel" text=""
                       styleClass="student-grade"/>

                <Label fx:id="visitorEntryExitLabel" text=""
                       styleClass="status-label"/>
            </VBox>

            <!-- Panel cuando no se encuentra -->
            <VBox fx:id="notFoundPanel" alignment="CENTER" spacing="15"
                  styleClass="not-found-panel" visible="false" managed="false">
                <padding>
                    <Insets top="20" right="30" bottom="20" left="30"/>
                </padding>

                <Label fx:id="notFoundLabel" text="No encontrado en el sistema"
                       styleClass="not-found-message"/>

                <Label fx:id="scannedCodeLabel" text=""
                       styleClass="scanned-code"/>

                <Button fx:id="quickRegisterButton" text="Registrar Nuevo Estudiante"
                        onAction="#onQuickRegister" styleClass="primary-button"/>
            </VBox>
        </VBox>
    </center>

    <!-- Panel lateral derecho con historial -->
    <right>
        <VBox styleClass="history-panel" prefWidth="280">
            <padding>
                <Insets top="20" right="15" bottom="20" left="15"/>
            </padding>

            <Label text="Historial Reciente" styleClass="history-title"/>

            <Separator/>

            <ListView fx:id="historyListView" VBox.vgrow="ALWAYS"
                      styleClass="history-list"/>

            <HBox alignment="CENTER" spacing="10">
                <padding>
                    <Insets top="10"/>
                </padding>
                <Button fx:id="clearHistoryButton" text="Limpiar"
                        onAction="#onClearHistory" styleClass="small-button"/>
            </HBox>
        </VBox>
    </right>

    <!-- Barra inferior con estado -->
    <bottom>
        <HBox styleClass="footer-box" alignment="CENTER_LEFT" spacing="20">
            <padding>
                <Insets top="10" right="20" bottom="10" left="20"/>
            </padding>

            <!-- Escudo del colegio (personalizable - clic para cambiar) -->
            <StackPane fx:id="shieldContainer" styleClass="shield-container"
                       onMouseClicked="#onShieldClick">
                <ImageView fx:id="schoolShieldImage" fitHeight="40" fitWidth="40"
                           preserveRatio="true" styleClass="school-shield"/>
                <Label fx:id="shieldPlaceholder" text="+ Escudo"
                       styleClass="shield-placeholder" visible="false"/>
            </StackPane>

            <Separator orientation="VERTICAL"/>

            <!-- Indicador de estado -->
            <HBox alignment="CENTER_LEFT" spacing="8">
                <Label fx:id="statusIndicator" text="" styleClass="status-indicator"/>
                <Label fx:id="connectionStatusLabel" text="Conectado" styleClass="connection-status"/>
            </HBox>

            <Region HBox.hgrow="ALWAYS"/>

            <!-- Información de licencia -->
            <Label fx:id="licenseInfoLabel" text="Modo Demo" styleClass="license-info"/>

            <Separator orientation="VERTICAL"/>

            <!-- Versión -->
            <Label text="v1.0.0" styleClass="version-label"/>
        </HBox>
    </bottom>
</BorderPane>
