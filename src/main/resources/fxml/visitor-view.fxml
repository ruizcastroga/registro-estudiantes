<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<!--
    Vista del módulo de visitantes.
    Permite registrar entrada/salida de visitantes usando carnés físicos.
    Incluye gestión de carnés e historial de visitas.
-->
<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.tuempresa.registro.controllers.VisitorController"
            styleClass="main-container">

    <!-- Barra superior -->
    <top>
        <VBox>
            <!-- Barra de sesión -->
            <HBox fx:id="sessionBar" alignment="CENTER_LEFT" spacing="15" styleClass="session-bar" visible="false" managed="false">
                <padding><Insets top="8" right="20" bottom="8" left="20"/></padding>
                <Label fx:id="sessionUserLabel" text="" styleClass="session-user-label"/>
                <Label fx:id="sessionRoleLabel" text="" styleClass="session-role-label"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="sessionTimerLabel" text="00:00" styleClass="session-timer-label"/>
                <Button fx:id="sessionLoginBtn" text="Iniciar Sesión" onAction="#onLogin" styleClass="session-button"/>
                <Button fx:id="sessionLogoutBtn" text="Cerrar Sesión" onAction="#onLogout" styleClass="session-button" visible="false" managed="false"/>
            </HBox>

            <!-- Header original -->
            <VBox styleClass="header-box">
                <HBox alignment="CENTER_LEFT" spacing="15">
                    <padding>
                        <Insets top="12" right="20" bottom="12" left="20"/>
                    </padding>

                    <!-- Left: title + subtitle -->
                    <VBox>
                        <Label text="Control de Visitantes" styleClass="app-title"/>
                        <Label fx:id="subtitleLabel" text="Escanee un carné para registrar entrada o salida"
                               styleClass="datetime-label"/>
                    </VBox>

                    <!-- Stats rápidas -->
                    <VBox alignment="CENTER" spacing="2">
                        <Label text="Dentro ahora" styleClass="stats-label"/>
                        <Label fx:id="insideCountLabel" text="0" styleClass="stats-value"/>
                    </VBox>
                    <VBox alignment="CENTER" spacing="2">
                        <Label text="Visitas hoy" styleClass="stats-label"/>
                        <Label fx:id="todayCountLabel" text="0" styleClass="stats-value"/>
                    </VBox>
                    <VBox alignment="CENTER" spacing="2">
                        <Label text="Carnés disponibles" styleClass="stats-label"/>
                        <Label fx:id="availableCountLabel" text="0" styleClass="stats-value"/>
                    </VBox>

                    <!-- Spacer: pushes nav buttons to the far right -->
                    <Region HBox.hgrow="ALWAYS"/>

                    <!-- Right: nav buttons (Visitantes greyed out = current module) -->
                    <Button text="Scanner"
                            onAction="#onBack" styleClass="secondary-button"/>
                    <Button text="Estudiantes"
                            onAction="#onManageStudents" styleClass="secondary-button"/>
                    <Button text="Visitantes" disable="true" styleClass="secondary-button"/>
                    <Button text="Personal"
                            onAction="#onManageStaff" styleClass="secondary-button"/>
                    <Button text="Creador de Carné"
                            onAction="#onManageCarne" styleClass="secondary-button"/>
                    <Button text="Ajustes"
                            onAction="#onManageSettings" styleClass="secondary-button"/>
                    <Button text="? Ayuda" onAction="#onHelp" styleClass="help-button"/>
                </HBox>
            </VBox>
        </VBox>
    </top>

    <!-- Área central: Visitantes Dentro Ahora -->
    <center>
        <VBox styleClass="history-panel">
            <padding>
                <Insets top="20" right="15" bottom="10" left="15"/>
            </padding>

            <Label text="Visitantes Dentro Ahora" styleClass="history-title"/>
            <Separator/>

            <TableView fx:id="insideTable" VBox.vgrow="ALWAYS" styleClass="history-list">
                <columns>
                    <TableColumn fx:id="colInsideBadge" text="Carné" prefWidth="90"/>
                    <TableColumn fx:id="colInsideName" text="Visitante" prefWidth="200"/>
                    <TableColumn fx:id="colInsideEntry" text="Entrada" prefWidth="100"/>
                </columns>
                <placeholder>
                    <Label text="Nadie dentro" styleClass="table-placeholder"/>
                </placeholder>
            </TableView>

            <Label text="Use el Scanner principal para registrar entradas y salidas"
                   styleClass="hint-label">
                <padding><Insets top="8"/></padding>
            </Label>
        </VBox>
    </center>


    <!-- Panel inferior: pestañas de gestión -->
    <bottom>
        <TabPane fx:id="managementTabs" tabClosingPolicy="UNAVAILABLE"
                 styleClass="management-tabs">

            <!-- Pestaña: Gestionar carnés -->
            <Tab text="Gestionar Carnés">
                <VBox spacing="10">
                    <padding>
                        <Insets top="12" right="15" bottom="12" left="15"/>
                    </padding>

                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Label text="Código nuevo:" styleClass="form-label"/>
                        <TextField fx:id="newBadgeCodeField"
                                   promptText="Ej: VISITANTE-01 o escanee aquí"
                                   onAction="#onAddBadge"
                                   prefWidth="220" styleClass="form-field"/>
                        <Button text="Agregar Carné" onAction="#onAddBadge"
                                styleClass="primary-button"/>
                        <Separator orientation="VERTICAL"/>
                        <Button text="Importar CSV" onAction="#onImportBadgesCsv"
                                styleClass="secondary-button"/>
                        <Button text="Plantilla" onAction="#onGenerateBadgesTemplate"
                                styleClass="small-button"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label text="(Todas las acciones requieren contraseña admin)"
                               styleClass="hint-label"/>
                    </HBox>

                    <TableView fx:id="badgesTable" prefHeight="220">
                        <columns>
                            <TableColumn fx:id="colBadgeCode" text="Código" prefWidth="200"/>
                            <TableColumn fx:id="colBadgeStatus" text="Estado" prefWidth="120"/>
                            <TableColumn fx:id="colBadgeUpdated" text="Actualizado" prefWidth="150"/>
                            <TableColumn fx:id="colBadgeActions" text="Acciones" prefWidth="250"/>
                        </columns>
                        <placeholder>
                            <Label text="Sin carnés registrados. Agregue uno arriba." styleClass="table-placeholder"/>
                        </placeholder>
                    </TableView>
                </VBox>
            </Tab>

            <!-- Pestaña: Historial de visitas -->
            <Tab text="Historial de Visitas">
                <VBox spacing="10">
                    <padding>
                        <Insets top="12" right="15" bottom="12" left="15"/>
                    </padding>

                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <TextField fx:id="logsSearchField"
                                   promptText="Buscar por carné, cédula, nombre..."
                                   prefWidth="320" styleClass="form-field"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button text="&#8659; Exportar CSV" onAction="#onExportLogs"
                                styleClass="small-button"/>
                        <Button text="Borrar Historial" onAction="#onPurgeLogs"
                                styleClass="danger-button"/>
                        <Button text="&#8635; Actualizar" onAction="#onRefreshLogs"
                                styleClass="small-button"/>
                    </HBox>

                    <TableView fx:id="logsTable" prefHeight="220">
                        <columns>
                            <TableColumn fx:id="colLogBadge" text="Carné" prefWidth="100"/>
                            <TableColumn fx:id="colLogId" text="Cédula" prefWidth="120"/>
                            <TableColumn fx:id="colLogName" text="Nombre" prefWidth="160"/>
                            <TableColumn fx:id="colLogJustification" text="Justificación" prefWidth="180"/>
                            <TableColumn fx:id="colLogEntry" text="Entrada" prefWidth="130"/>
                            <TableColumn fx:id="colLogExit" text="Salida" prefWidth="130"/>
                        </columns>
                        <placeholder>
                            <Label text="Sin registros de visitas." styleClass="table-placeholder"/>
                        </placeholder>
                    </TableView>
                </VBox>
            </Tab>
        </TabPane>
    </bottom>
</BorderPane>
